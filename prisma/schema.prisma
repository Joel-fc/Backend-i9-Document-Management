generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  password String  // Aqui ficará o hash (criptografia) depois
}

model Project {
  id          String    @id @default(uuid())
  title       String
  description String    @db.Text
  imageUrl    String?
  status      ProjectStatus @default(PLANNING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startDate   DateTime?
  endDate     DateTime?
  clientName  String?
  projectUrl  String?
}

enum ProjectStatus {
  PLANNING     // Planejamento
  IN_PROGRESS  // Em execução
  COMPLETED    // Finalizado
  CANCELED     // Cancelado
}